// HealthLocker — Prisma schema
//
// Conventions used throughout:
//   * Provider-owned rows carry `orgId` (the tenant). Every query is scoped by a
//     server-side guard; the client is never trusted for tenancy.
//   * Medical and financial rows are SOFT-deleted (`deletedAt`) — a health record
//     is never physically removed, and AuditLog rows are never deleted at all.
//   * Money is an Int count of the smallest currency unit (paise). Never a float.
//   * Enum names mirror src/shared/enums.ts exactly.
//   * AI-derived fields carry provenance (provider/model/confidence) plus a
//     human `confirmedAt`, so low-confidence data can always be traced and fixed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon POOLED connection string (…-pooler.…) — used by the app at runtime.
  url       = env("DATABASE_URL")
  // Neon DIRECT connection — `prisma migrate` cannot run through a pooler.
  directUrl = env("DIRECT_URL")
}

