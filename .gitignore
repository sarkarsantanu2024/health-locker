# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets never get committed, the documented template does
.env*
!infra/.env.example

# vercel
.vercel

# Local-only notes, never committed. Demo logins and other throwaway
# credentials live in *.local.md so they are handy but stay out of a public repo.
*.local.md
/secrets/

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor — the Android project is generated by `pnpm android:add`, and the
# fallback shell by `pnpm android:shell`. Build outputs are never committed.
/android-shell/
/android/app/build/
/android/build/
/android/.gradle/
/android/local.properties
/android/app/src/main/assets/public/
/android/app/src/main/assets/capacitor.config.json
/android/app/src/main/assets/capacitor.plugins.json
*.apk
*.aab
