# HealthLocker — environment configuration
#
#   cp infra/.env.example .env
#
# Only the REQUIRED block is needed to run `pnpm dev`. Everything else is
# validated lazily at the point of use (src/lib/env.ts), so the app boots fine
# with the cloud services still unconfigured.

# ============================================================================
# REQUIRED
# ============================================================================

# Local (docker compose -f infra/docker-compose.yml up -d):
DATABASE_URL="postgresql://healthlocker:healthlocker@localhost:5432/healthlocker?schema=public"
DIRECT_URL="postgresql://healthlocker:healthlocker@localhost:5432/healthlocker?schema=public"

# Neon (production): DATABASE_URL must be the POOLED host (…-pooler.…) because
# serverless functions open many short-lived connections. DIRECT_URL is the
# non-pooled host — `prisma migrate` cannot run through a transaction pooler.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/healthlocker?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/healthlocker?sslmode=require"

# >= 32 chars. Generate: openssl rand -base64 48
AUTH_JWT_SECRET="dev-only-change-me-dev-only-change-me-1234"

# ============================================================================
# APP
# ============================================================================
APP_NAME="HealthLocker"
APP_URL="http://localhost:3000"

# ============================================================================
# AUTH (optional — sane defaults in src/lib/env.ts)
# ============================================================================
# AUTH_ACCESS_TOKEN_TTL=900            # seconds (15 min)
# AUTH_REFRESH_TOKEN_TTL=2592000       # seconds (30 days)
# AUTH_COOKIE_PREFIX="hl"
# AES-256-GCM key for encrypting sensitive columns. 32 bytes, base64.
# Generate: openssl rand -base64 32
# ENCRYPTION_KEY=""

# ============================================================================
# UPSTASH — cache, rate limiting, background jobs, scheduled reminders
# Wired in Phase 2 (rate limit) and Phase 4/5 (jobs, reminders).
# ============================================================================
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
# QSTASH_TOKEN=""
# QSTASH_CURRENT_SIGNING_KEY=""
# QSTASH_NEXT_SIGNING_KEY=""

# ============================================================================
# OBJECT STORAGE — Cloudflare R2 (S3 API). Wired in Phase 4.
# ============================================================================
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="healthlocker-documents"
# Local MinIO instead of Cloudflare (docker compose profile "storage"):
# R2_ENDPOINT="http://localhost:9000"
# R2_ACCESS_KEY_ID="healthlocker"
# R2_SECRET_ACCESS_KEY="healthlocker"
# R2_BUCKET="healthlocker-documents"

# ============================================================================
# WEB PUSH — the only automated push channel. No email, no SMS.
# Generate a key pair: pnpm dlx web-push generate-vapid-keys
# ============================================================================
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:ops@yourdomain.com"

# ============================================================================
# AI / OCR — free tier. `mock` is deterministic and used by dev + CI.
# ============================================================================
AI_PROVIDER="mock"                     # mock | gemini | groq
# GEMINI_API_KEY=""
# GROQ_API_KEY=""

# ============================================================================
# JOBS — shared secret for Vercel Cron → /api/jobs/*. QStash uses signatures.
# ============================================================================
# CRON_SECRET=""
