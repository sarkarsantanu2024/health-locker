<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon foreground: the HealthLocker mark — a padlock shackle over a
  locker body holding a medical cross, with a pulse across it.

  Drawn on the same 512 grid as public/icon.svg so the three renderings of the
  mark (web favicon, PWA icon, Android launcher) are one piece of artwork.

  The 0.92 scale about the centre is not decorative: an adaptive icon only
  guarantees the centre 66.7% of the canvas survives the launcher's mask, and at
  1.0 the top of the shackle sits a few units outside it on a circular mask.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
    <group
        android:pivotX="256"
        android:pivotY="256"
        android:scaleX="0.92"
        android:scaleY="0.92">

        <!-- Shackle. Deliberately not closed — an open locker you own, not a vault. -->
        <path
            android:pathData="M176,216 V176 a80,80 0 0 1 160,0 v40"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="34"
            android:strokeLineCap="round"
            android:strokeAlpha="0.9" />

        <!-- Locker body. -->
        <path
            android:pathData="M168,216 H344 a32,32 0 0 1 32,32 v120 a32,32 0 0 1 -32,32 H168 a32,32 0 0 1 -32,-32 V248 a32,32 0 0 1 32,-32 z"
            android:fillColor="#FFFFFFFF" />

        <!-- Cross. -->
        <path
            android:pathData="M256,262 V354 M210,308 H302"
            android:strokeColor="#FF0F7A6C"
            android:strokeWidth="30"
            android:strokeLineCap="round" />

        <!-- Pulse — the sign of life in the record. -->
        <path
            android:pathData="M168,362 h34 l16,-30 l22,52 l18,-36 l14,22 h44"
            android:strokeColor="#FF22B8A0"
            android:strokeWidth="14"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:strokeAlpha="0.65" />
    </group>
</vector>
