<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8+). Both layers are vectors generated from
  the same mark as public/icon.svg, so there is one drawing of the brand rather
  than one per platform. The PNGs in mipmap-*/ are the API 24-25 fallback and
  come from `pnpm android:icons`.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
    <!-- Android 13 themed icons: the launcher tints this with the wallpaper palette. -->
    <monochrome android:drawable="@drawable/ic_launcher_monochrome"/>
</adaptive-icon>
