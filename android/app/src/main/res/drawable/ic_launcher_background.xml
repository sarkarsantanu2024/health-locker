<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon background: the brand gradient, as a vector rather than five
  PNGs. Adaptive icons are 108x108dp of which only the centre 72x72dp is
  guaranteed visible — the launcher crops the rest to whatever shape the device
  uses — so nothing meaningful goes here. The artwork is in
  ic_launcher_foreground.xml, inside the safe zone.

  Matches public/icon.svg and <LogoMark> in src/ui/logo.tsx. Edit together.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0" android:color="#FF0F7A6C" />
                <item android:offset="1" android:color="#FF22B8A0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
